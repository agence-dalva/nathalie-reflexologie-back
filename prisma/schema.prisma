// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum EmailTemplateType {
  CONFIRMATION
  CANCELLATION
  MODIFICATION
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@map("admin_users")
}

model RefreshToken {
  id          Int       @id @default(autoincrement())
  tokenHash   String    @unique @map("token_hash")
  adminUserId Int       @map("admin_user_id")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([adminUserId])
  @@map("refresh_tokens")
}

model Service {
  id              Int      @id @default(autoincrement())
  name            String
  description     String?
  durationMinutes Int      @map("duration_minutes")
  bufferMinutes   Int      @default(0) @map("buffer_minutes")
  price           Decimal  @default(0) @db.Decimal(10, 2)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bookings Booking[]

  @@map("services")
}

// Horaires récurrents par jour de semaine (0=lundi ... 6=dimanche)
model Availability {
  id        Int      @id @default(autoincrement())
  weekday   Int
  startTime DateTime @map("start_time") @db.Time()
  endTime   DateTime @map("end_time") @db.Time()
  createdAt DateTime @default(now()) @map("created_at")

  @@index([weekday])
  @@map("availabilities")
}

// Jours fermés / vacances / horaires modifiés ponctuellement
model Exception {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  isClosed  Boolean  @default(true) @map("is_closed")
  startTime DateTime? @map("start_time") @db.Time()
  endTime   DateTime? @map("end_time") @db.Time()
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@map("exceptions")
}

model Booking {
  id                 Int           @id @default(autoincrement())
  serviceId          Int           @map("service_id")
  service            Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  clientId           Int?          @map("client_id")
  client             Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerFirstname  String        @map("customer_firstname")
  customerLastname   String        @map("customer_lastname")
  customerEmail      String        @map("customer_email")
  customerPhone      String?       @map("customer_phone")
  beneficiaryFirstname String?     @map("beneficiary_firstname")
  beneficiaryLastname  String?     @map("beneficiary_lastname")
  beneficiaryPhone     String?     @map("beneficiary_phone")
  notes              String?
  startsAt           DateTime      @map("starts_at") @db.Timestamptz()
  endsAt             DateTime      @map("ends_at") @db.Timestamptz()
  status             BookingStatus @default(CONFIRMED)
  cancelToken        String        @default(uuid()) @map("cancel_token")
  idempotencyKey     String?       @unique @map("idempotency_key")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@index([startsAt])
  @@index([customerEmail])
  @@index([cancelToken])
  @@index([clientId])
  @@map("bookings")
}

model Client {
  id        Int      @id @default(autoincrement())
  firstname String
  lastname  String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings Booking[]

  @@map("clients")
}

model EmailTemplate {
  id        Int               @id @default(autoincrement())
  type      EmailTemplateType @unique
  subject   String
  title     String
  body      String
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@map("email_templates")
}
